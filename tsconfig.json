{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "src/web"
  ]
}